      <ldd>6.0e-4</ldd>
      <TI>8760</TI>
      <MTTR>16</MTTR>
      <beta>12</beta>
      <betad>12</betad>
      <M>2</M>
      <N>3</N>
      <partialTest>false</partialTest>
      <MT>87600</MT>
      <ptc>0</ptc>
