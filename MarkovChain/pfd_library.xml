      <ldu>2.0e-6</ldu>
      <ldd>3.0e-5</ldd>
      <TI>8760</TI>
      <MTTR>8</MTTR>
      <beta>3</beta>
      <betad>3</betad>
      <M>1</M>
      <N>1</N>
      <partialTest>false</partialTest>
