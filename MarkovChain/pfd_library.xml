      <ldu>5.0e-7</ldu>
      <ldd>1.0e-5</ldd>
      <TI>8760</TI>
      <MTTR>24</MTTR>
      <beta>2</beta>
      <betad>2</betad>
      <M>1</M>
      <N>1</N>
      <partialTest>true</partialTest>
      <MT>4380</MT>
      <ptc>60</ptc>
    </component>

  </category>

  <!-- ═══════════════════════════════════════════════ FINAL ELEMENTS ═══ -->
