<?xml version="1.0" encoding="UTF-8"?>
<!--
  PFD Component Library — IEC 61508 / ISA-84
  Failure rates (λdu, λdd) in h⁻¹
  TI  : Test Interval (h)
  MT  : Manual Test interval for partial test (h)
  MTTR: Mean Time To Restore (h)
  beta, betad: Common Cause Failure factors (%)
  M, N: MooN voting architecture
  ptc : Partial Test Coverage (%)
  partialTest: true | false
-->
<pfd_library version="1.0" standard="IEC 61508 / ISA-84">

  <!-- ═══════════════════════════════════════════════════ SENSORS ═══ -->
  <category type="sensor">

    <component id="S01">
      <name>Pressure Transmitter (1oo1)</name>
      <description>Smart pressure transmitter, single channel — typical subsea/topside application</description>
      <ldu>1.0e-6</ldu>
      <ldd>2.5e-5</ldd>
      <TI>8760</TI>
      <MTTR>8</MTTR>
      <beta>5</beta>
      <betad>5</betad>
      <M>1</M>
      <N>1</N>
      <partialTest>false</partialTest>
      <MT>87600</MT>
      <ptc>0</ptc>
    </component>

    <component id="S02">
      <name>Pressure Transmitter (1oo2)</name>
      <description>Redundant pressure transmitters with 1oo2 voting — enhanced availability</description>
      <ldu>1.0e-6</ldu>
      <ldd>2.5e-5</ldd>
      <TI>8760</TI>
      <MTTR>8</MTTR>
      <beta>5</beta>
      <betad>5</betad>
      <M>1</M>
      <N>2</N>
      <partialTest>false</partialTest>
      <MT>87600</MT>
      <ptc>0</ptc>
    </component>

    <component id="S03">
      <name>Temperature Transmitter (1oo2)</name>
      <description>Dual RTD/thermocouple transmitter for high-temperature process protection</description>
      <ldu>2.0e-6</ldu>
      <ldd>4.0e-5</ldd>
      <TI>8760</TI>
      <MTTR>12</MTTR>
      <beta>8</beta>
      <betad>8</betad>
      <M>1</M>
      <N>2</N>
      <partialTest>false</partialTest>
      <MT>87600</MT>
      <ptc>0</ptc>
    </component>

    <component id="S04">
      <name>Gas Detector (2oo3)</name>
      <description>Catalytic bead or IR gas detectors in 2oo3 voting — fire and gas system</description>
      <ldu>5.0e-6</ldu>
      <ldd>1.0e-4</ldd>
      <TI>4380</TI>
      <MTTR>8</MTTR>
      <beta>10</beta>
      <betad>10</betad>
      <M>2</M>
      <N>3</N>
      <partialTest>false</partialTest>
      <MT>87600</MT>
      <ptc>0</ptc>
    </component>

    <component id="S05">
      <name>Level Switch (1oo2) with Partial Test</name>
      <description>Guided-wave radar level switch, 1oo2 voting with 6-month partial stroke test</description>
      <ldu>3.0e-6</ldu>
      <ldd>6.0e-5</ldd>
      <TI>8760</TI>
      <MTTR>8</MTTR>
      <beta>6</beta>
      <betad>6</betad>
      <M>1</M>
      <N>2</N>
      <partialTest>true</partialTest>
      <MT>4380</MT>
      <ptc>70</ptc>
    </component>

  </category>

  <!-- ════════════════════════════════════════════════ LOGIC SOLVERS ═══ -->
  <category type="logic">

